<configuration>
    <springProperty scope="context" name="RUN_DATE" source="app.run-date" defaultValue="unknown-date"/>
    <springProperty scope="context" name="RERUN_ID" source="app.rerun-id" defaultValue="no-rerun-id"/>

    <property name="LOG_DIR" value="./logs/${RUN_DATE}"/>
    <property name="LOG_FILE" value="${LOG_DIR}/dedupe-batch-${RERUN_ID}.log"/>
    <property name="CONSOLE_PATTERN" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%-5level logger=%logger{36} thread=%thread msg=%msg%n%ex"/>
    <property name="FILE_PATTERN" value="%d{yyyy-MM-dd'T'HH:mm:ss.SSSXXX} level=%-5level logger=%logger{36} thread=%thread msg=%msg%n%ex"/>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <append>true</append>

        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/dedupe-batch-${RERUN_ID}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>50MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <logger name="org.springframework.batch" level="INFO"/>
    <logger name="com.bnk.files.dedup" level="INFO"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>